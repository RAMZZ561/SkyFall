-- CORE FRAME LOOP
RunService.RenderStepped:Connect(function(dt)
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        if hum then
            hum.WalkSpeed = Config.WalkSpeed
            hum.JumpPower = Config.JumpPower
        end

        if Config.Fly.Enabled and hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
            local dir = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
            if dir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + dir.Unit * Config.Fly.Speed * dt end
        end

        if Config.Noclip then
            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end

    -- DRAW FOV
    if DrawingEnabled and FOVCircle then
        FOVCircle.Visible = Config.Aimbot.Enabled and (Config.Aimbot.Mode ~= "Rage")
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Radius = Config.Aimbot.FOV
    end

    -- HIGH QUALITY OUTLINE ESP LOOP
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")

                        if not hrp or not humanoid or humanoid.Health <= 0 then
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do pcall(function() obj:Remove() end) end
                    ESPObjects[player] = nil
                end
                continue
            end

            if Config.ESP.Enabled and DrawingEnabled then
                if not ESPObjects[player] then
                    ESPObjects[player] = {
                        BoxOutline = DrawingAPI.new("Square"),
                        Box = DrawingAPI.new("Square"),
                        HealthBarBg = DrawingAPI.new("Square"),
                        HealthBar = DrawingAPI.new("Square"),
                        Line = DrawingAPI.new("Line"),
                        Text = DrawingAPI.new("Text")
                    }
                end
                
                local objs = ESPObjects[player]
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

                if onScreen then
                    local top = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.2, 0))
                    local bot = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, -3.8, 0))
                    local boxHeight = math.abs(top.Y - bot.Y)
                    local boxWidth = boxHeight * 0.58
                    local boxX = pos.X - (boxWidth / 2)
                    local boxY = top.Y

                    -- Box Render (Dual-layer Outline)
                    if Config.ESP.Box then
                        objs.BoxOutline.Size = Vector2.new(boxWidth, boxHeight)
                        objs.BoxOutline.Position = Vector2.new(boxX, boxY)
                        objs.BoxOutline.Color = Color3.fromRGB(0,0,0)
                        objs.BoxOutline.Thickness = 2.5
                        objs.BoxOutline.Filled = false
                        objs.BoxOutline.Visible = true

                        objs.Box.Size = Vector2.new(boxWidth, boxHeight)
                        objs.Box.Position = Vector2.new(boxX, boxY)
                        objs.Box.Color = Config.ESP.Color
                        objs.Box.Thickness = 1
                        objs.Box.Filled = false
                        objs.Box.Visible = true
                    else
                        objs.BoxOutline.Visible = false
                        objs.Box.Visible = false
                    end

                    -- Dynamic Health Bar
                    if Config.ESP.Health then
                        local healthPerc = humanoid.Health / humanoid.MaxHealth
                        local barHeight = boxHeight * healthPerc
                        local barColor = Color3.fromRGB(255, 0, 0):Lerp(C.Green, healthPerc)

                        objs.HealthBarBg.Size = Vector2.new(3, boxHeight)
                        objs.HealthBarBg.Position = Vector2.new(boxX - 6, boxY)
                        objs.HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
                        objs.HealthBarBg.Filled = true
                        objs.HealthBarBg.Visible = true

                        objs.HealthBar.Size = Vector2.new(1, barHeight)
                        objs.HealthBar.Position = Vector2.new(boxX - 5, boxY + (boxHeight - barHeight))
                        objs.HealthBar.Color = barColor
                        objs.HealthBar.Filled = true
                        objs.HealthBar.Visible = true
                    else
                        objs.HealthBarBg.Visible = false
                        objs.HealthBar.Visible = false
                    end

                    -- Snap Tracers
                    if Config.ESP.Tracer then
                        objs.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        objs.Line.To = Vector2.new(pos.X, pos.Y + (boxHeight/2))
                        objs.Line.Color = Config.ESP.Color
                        objs.Line.Thickness = 1
                        objs.Line.Visible = true
                    else
                        objs.Line.Visible = false
                    end

                    -- Clean Identity Tags
                    if Config.ESP.Name then
                        objs.Text.Text = player.Name
                        objs.Text.Size = 12
                        objs.Text.Center = true
                        objs.Text.Outline = true
                        objs.Text.Position = Vector2.new(pos.X, boxY - 15)
                        objs.Text.Color = C.Text
                        objs.Text.Visible = true
                    else
                        objs.Text.Visible = false
                    end
                else
                    for _, obj in pairs(objs) do obj.Visible = false end
                end
            else
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do pcall(function() obj:Remove() end) end
                    ESPObjects[player] = nil
                end
            end
        end
    end

    -- ADVANCED AIMBOT ENGINE (3 MODES)
    if Config.Aimbot.Enabled then
        local mode = Config.Aimbot.Mode
        local isRage = (mode == "Rage")
        local shouldLock = isRage or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

        if shouldLock then
            local target = nil
            local maxDistance = isRage and 999999 or Config.Aimbot.FOV
            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            
            -- Determinasi Struktur Tulang Berdasarkan Mode
            local targetBone = Config.Aimbot.TargetPart
            if mode == "Legit" then
                local randomBones = {"HumanoidRootPart", "Neck", "Head"}
                targetBone = randomBones[math.random(1, #randomBones)]
                maxDistance = Config.Aimbot.FOV * 0.6
            elseif mode == "Rage" then
                targetBone = "Head"
            end

            for _, other in pairs(Players:GetPlayers()) do
                if other ~= LocalPlayer and other.Character then
                    local part = other.Character:FindFirstChild(targetBone)
                    local otherHum = other.Character:FindFirstChildOfClass("Humanoid")
                    
                    if part and otherHum and otherHum.Health > 0 then
                        local screenPos, vis = Camera:WorldToViewportPoint(part.Position)
                        if vis or isRage then
                            local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if distanceToCenter < maxDistance then
                                maxDistance = distanceToCenter
                                target = part
                            end
                        end
                    end
                end
            end

            if target then
                local goalCF = CFrame.lookAt(Camera.CFrame.Position, target.Position)
                
                if mode == "Rage" then
                    Camera.CFrame = goalCF
                elseif mode == "Legit" then
                    local extraSmooth = Config.Aimbot.Smoothness * 0.5
                    Camera.CFrame = Camera.CFrame:Lerp(goalCF, math.clamp(extraSmooth, 0.01, 1))
                else
                    Camera.CFrame = Camera.CFrame:Lerp(goalCF, math.clamp(Config.Aimbot.Smoothness, 0.05, 1))
                end
            end
        end
    end
end)

