    Create("TextLabel", {Size = UDim2.new(1, -70, 0, 14), Position = UDim2.new(0, 12, 0, 24), BackgroundTransparency = 1, Text = desc, TextColor3 = C.Subtext, Font = Enum.Font.Gotham, TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left}, card)

    local toggleBg = Create("Frame", {Size = UDim2.new(0, 34, 0, 18), Position = UDim2.new(1, -44, 0.5, -9), BackgroundColor3 = default and C.Accent or C.Sidebar, BorderSizePixel = 0}, card)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, toggleBg)
    local toggleCircle = Create("Frame", {Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(0, default and 18 or 2, 0.5, -7), BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0}, toggleBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, toggleCircle)

    local active = default
    Create("TextButton", {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""}, card).MouseButton1Click:Connect(function()
        active = not active
        toggleBg.BackgroundColor3 = active and C.Accent or C.Sidebar
        TweenService:Create(toggleCircle, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {Position = UDim2.new(0, active and 18 or 2, 0.5, -7)}):Play()
        callback(active)
    end)
end

local function CreateSliderCard(title, parent, order, default, min, max, callback)
    local card = Create("Frame", {Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = C.Card, BorderSizePixel = 0, LayoutOrder = order}, parent)
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, card)
    Create("UIStroke", {Color = C.CardBorder, Thickness = 1}, card)

    Create("TextLabel", {Size = UDim2.new(0, 150, 0, 16), Position = UDim2.new(0, 12, 0, 6), BackgroundTransparency = 1, Text = title, TextColor3 = C.Text, Font = Enum.Font.GothamBold, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left}, card)
    local valLabel = Create("TextLabel", {Size = UDim2.new(0, 50, 0, 16), Position = UDim2.new(1, -62, 0, 6), BackgroundTransparency = 1, Text = tostring(default), TextColor3 = C.AccentLight, Font = Enum.Font.GothamBold, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Right}, card)

    local sliderBg = Create("Frame", {Size = UDim2.new(1, -24, 0, 6), Position = UDim2.new(0, 12, 0, 32), BackgroundColor3 = C.Sidebar, BorderSizePixel = 0}, card)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderBg)
    local sliderFill = Create("Frame", {Size = UDim2.new((default - min) / (max - min), 0, 1, 0), BackgroundColor3 = C.Accent, BorderSizePixel = 0}, sliderBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderFill)

    local function UpdateSlider(inputX)
        local rel = math.clamp((inputX - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        sliderFill.Size = UDim2.new(rel, 0, 1, 0)
        local val = math.floor(min + (max - min) * rel)
        valLabel.Text = tostring(val)
        callback(val)
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            UpdateSlider(input.Position.X)
            local connection
            connection = UserInputService.InputChanged:Connect(function(moveInput)
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    UpdateSlider(moveInput.Position.X)
                else
                    connection:Disconnect()
                end
            end)
        end
    end)
end

local function CreateSelectorCard(title, options, parent, order, default, callback)
    local card = Create("Frame", {Size = UDim2.new(1, 0, 0, 54), BackgroundColor3 = C.Card, BorderSizePixel = 0, LayoutOrder = order}, parent)
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, card)
    Create("UIStroke", {Color = C.CardBorder, Thickness = 1}, card)

    Create("TextLabel", {Size = UDim2.new(0, 100, 1, 0), Position = UDim2.new(0, 12, 0, 0), BackgroundTransparency = 1, Text = title, TextColor3 = C.Text, Font = Enum.Font.GothamBold, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left}, card)

    local container = Create("Frame", {Size = UDim2.new(1, -130, 0, 30), Position = UDim2.new(0, 118, 0.5, -15), BackgroundTransparency = 1}, card)
    local layout = Create("UIListLayout", {FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 4), HorizontalAlignment = Enum.HorizontalAlignment.Right}, container)

    local currentActive = default
    local buttons = {}

    for _, opt in ipairs(options) do
        local btn = Create("TextButton", {
            Size = UDim2.new(0, 65, 1, 0),
            BackgroundColor3 = opt == default and C.Accent or C.Sidebar,
            BorderSizePixel = 0,
            Text = opt,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            Font = Enum.Font.GothamSemibold,
            TextSize = 10
        }, container)
        Create("UICorner", {CornerRadius = UDim.new(0, 4)}, btn)
        buttons[opt] = btn

        btn.MouseButton1Click:Connect(function()
            currentActive = opt
            for name, b in pairs(buttons) do b.BackgroundColor3 = (name == currentActive) and C.Accent or C.Sidebar end
            callback(opt)
        end)
    end
end

