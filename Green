-- ★ DRAG LOGIC: ONLY ON TOPBAR (prevents slider conflict)
local FrameDragging, DragStart, StartPos = false, nil, nil

TopBar.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not SliderActive then
        FrameDragging = true
        DragStart = input.Position
        StartPos = MainFrame.Position
    end
end)

TopBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        FrameDragging = false
    end
end)

-- ★ GLOBAL INPUT CHANGED: handles BOTH frame drag and slider drag
UserInputService.InputChanged:Connect(function(input)
    -- Slider drag (priority)
    if SliderActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        -- Find all active sliders and update (handled by individual slider connections below)
    end
    -- Frame drag
    if FrameDragging and not SliderActive and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + delta.X, StartPos.Y.Scale, StartPos.Y.Offset + delta.Y)
    end
end)

-- ★ GLOBAL INPUT ENDED: clear slider flag on mouse release anywhere
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        SliderActive = nil
    end
end)

