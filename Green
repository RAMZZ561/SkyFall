    local toggleBg = Create("Frame", {Size = UDim2.new(0, 38, 0, 20), Position = UDim2.new(1, -48, 0.5, -10), BackgroundColor3 = default and C.Accent or C.Sidebar, BorderSizePixel = 0}, card)
