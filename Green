-- ==================== MAIN EXECUTION LOOP ====================
RunService.RenderStepped:Connect(function(dt)
    -- Movement
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        if hum then
            hum.WalkSpeed = Config.WalkSpeed
            hum.JumpPower = Config.JumpPower
        end

        -- Fly
        if Config.Fly.Enabled and hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
            local dir = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
            if dir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + dir.Unit * (Config.FlySpeed or Config.Fly.Speed or 60) * dt end
        end

        -- Noclip
        if Config.Noclip then
            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end

    -- Infinite Jump
    if Config.InfiniteJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    -- Anti AFK
    if Config.AntiAFK and math.random(1, 500) == 1 then
        pcall(function()
            local vu = Instance.new("VirtualUser"); vu:CaptureController(); vu:ClickButton2(Vector2.new())
        end)
    end

    -- FOV Circle
    if DrawingEnabled and FOVCircle then
        FOVCircle.Visible = Config.Aimbot.Enabled
        FOVCircle.Position = Vector2.new(Mouse.X, Mouse.Y + 36)
    end

    -- ESP & Aimbot
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")

            if not hrp or not humanoid or humanoid.Health <= 0 then
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do pcall(function() obj:Remove() end) end
                    ESPObjects[player] = nil
                end
                continue
            end

            -- ESP
            if Config.ESP.Enabled and DrawingEnabled then
                if not ESPObjects[player] then ESPObjects[player] = {} end
                local objs = ESPObjects[player]
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

                if onScreen then
                    local headPos = player.Character:FindFirstChild("Head") and Camera:WorldToViewportPoint(player.Character.Head.Position) or pos

                    -- Box
                    if Config.ESP.Box then
                        if not objs.Box then objs.Box = DrawingAPI.new("Square"); objs.Box.Thickness = 1; objs.Box.Filled = false end
                        local top = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-2, 3, 0))
                        local bot = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(2, -3, 0))
                        objs.Box.Size = Vector2.new(math.abs(bot.X - top.X), math.abs(bot.Y - top.Y))
                        objs.Box.Position = Vector2.new(top.X, top.Y)
                        objs.Box.Color = Config.ESP.Color
                        objs.Box.Visible = true
                    elseif objs.Box then objs.Box.Visible = false end

                    -- Tracer
                    if Config.ESP.Tracer then
                        if not objs.Line then objs.Line = DrawingAPI.new("Line"); objs.Line.Thickness = 1 end
                        objs.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        objs.Line.To = Vector2.new(pos.X, pos.Y)
                        objs.Line.Color = Config.ESP.Color
                        objs.Line.Visible = true
                    elseif objs.Line then objs.Line.Visible = false end

                    -- Text (Name + Health + Distance)
                    if Config.ESP.Name or Config.ESP.Health or Config.ESP.Distance then
                        if not objs.Text then objs.Text = DrawingAPI.new("Text"); objs.Text.Size = 13; objs.Text.Center = true; objs.Text.Outline = true end
                        local str = ""
                        if Config.ESP.Name then str = str .. player.Name end
                        if Config.ESP.Health then str = str .. (str ~= "" and "\n" or "") .. math.floor(humanoid.Health) .. " HP" end
                        if Config.ESP.Distance then str = str .. (str ~= "" and "\n" or "") .. math.floor((hrp.Position - Camera.CFrame.Position).Magnitude) .. " studs" end
                        objs.Text.Text = str
                        objs.Text.Position = Vector2.new(pos.X, pos.Y - 50)
                        objs.Text.Color = Config.ESP.Color
                        objs.Text.Visible = true
                    elseif objs.Text then objs.Text.Visible = false end
                else
                    if objs.Box then objs.Box.Visible = false end
                    if objs.Line then objs.Line.Visible = false end
                    if objs.Text then objs.Text.Visible = false end
                end
            else
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do pcall(function() obj:Remove() end) end
                    ESPObjects[player] = nil
                end
            end

            -- AIMBOT
            if Config.Aimbot.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                local target = nil
                local minDist = Config.Aimbot.FOV
                local targetPartName = Config.Aimbot.TargetPart or "Head"

                for _, other in pairs(Players:GetPlayers()) do
                    if other ~= LocalPlayer and other.Character then
                        local part = other.Character:FindFirstChild(targetPartName) or other.Character:FindFirstChild("Head")
                        local otherHum = other.Character:FindFirstChildOfClass("Humanoid")
                        if part and otherHum and otherHum.Health > 0 then
                            local screenPos, vis = Camera:WorldToViewportPoint(part.Position)
                            if vis then
                                local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y + 36)).Magnitude
                                if dist < minDist then
                                    minDist = dist
                                    target = part
                                end
                            end
                        end
                    end
                end

                if target then
                    local goalCF = CFrame.lookAt(Camera.CFrame.Position, target.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(goalCF, math.clamp(Config.Aimbot.Smoothness, 0.05, 1))
                end
            end
        end
    end
end)

