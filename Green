    end)
end

-- ★ FIXED SLIDER FUNCTION
local function CreateSliderCard(title, desc, icon, parent, order, default, min, max, callback)
    local card = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 62),
        BackgroundColor3 = C.Card,
        BorderSizePixel = 0,
        LayoutOrder = order
    }, parent)
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, card)
    Create("UIStroke", {Color = C.CardBorder, Thickness = 1}, card)

    local iconFrame = Create("Frame", {Size = UDim2.new(0, 36, 0, 36), Position = UDim2.new(0, 8, 0, 8), BackgroundColor3 = C.Sidebar, BorderSizePixel = 0}, card)
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, iconFrame)
    Create("TextLabel", {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = icon, TextSize = 18}, iconFrame)

    Create("TextLabel", {Size = UDim2.new(1, -110, 0, 14), Position = UDim2.new(0, 50, 0, 8), BackgroundTransparency = 1, Text = title, TextColor3 = C.Text, Font = Enum.Font.GothamBold, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left}, card)

    local valLabel = Create("TextLabel", {Size = UDim2.new(0, 40, 0, 14), Position = UDim2.new(1, -50, 0, 8), BackgroundTransparency = 1, Text = tostring(default), TextColor3 = C.AccentLight, Font = Enum.Font.GothamBold, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right}, card)

    -- Slider track
    local sliderBg = Create("Frame", {
        Size = UDim2.new(1, -24, 0, 10),
        Position = UDim2.new(0, 12, 0, 42),
        BackgroundColor3 = C.Sidebar,
        BorderSizePixel = 0,
        Active = true
    }, card)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderBg)

    local sliderFill = Create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = C.Accent,
        BorderSizePixel = 0
    }, sliderBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderFill)

    -- Slider knob
    local knob = Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        ZIndex = 3
    }, sliderBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, knob)

    -- ★ SLIDER INPUT: Sets global flag to block frame drag
    local function UpdateSlider(inputX)
        local absPos = sliderBg.AbsolutePosition.X
        local absSize = sliderBg.AbsoluteSize.X
        if absSize <= 0 then return end
        local rel = math.clamp((inputX - absPos) / absSize, 0, 1)
        sliderFill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        local val = math.floor(min + (max - min) * rel)
        valLabel.Text = tostring(val)
        if callback then callback(val) end
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            SliderActive = true
            UpdateSlider(input.Position.X)
        end
    end)

    sliderBg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            SliderActive = nil
        end
    end)

    -- Also capture input on knob
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            SliderActive = true
        end
    end)
end

