-- Functions
local function GetClosestPlayer()
    local Target = nil
    local Distance = AimbotSettings.FOV
    
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(AimbotSettings.TargetPart) then
            if AimbotSettings.TeamCheck and v.Team == LocalPlayer.Team then continue end
            
            local ScreenPoint = Camera:WorldToScreenPoint(v.Character[AimbotSettings.TargetPart].Position)
            local Mag = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
            
            if Mag < Distance then
                if AimbotSettings.WallCheck then
                    local Ray = Ray.new(Camera.CFrame.Position, (v.Character[AimbotSettings.TargetPart].Position - Camera.CFrame.Position).Unit * 500)
                    local Hit = workspace:FindPartOnRayWithIgnoreList(Ray, {LocalPlayer.Character, v.Character})
                    if Hit then continue end
                end
                Distance = Mag
                Target = v
            end
        end
    end
    return Target
end

