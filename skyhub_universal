-- Logic Loop
RunService.RenderStepped:Connect(function()
    if AimbotSettings.Enabled then
        local Target = GetClosestPlayer()
        if Target and Target.Character and Target.Character:FindFirstChild(AimbotSettings.TargetPart) then
            local TargetPos = Target.Character[AimbotSettings.TargetPart].Position
            if AimbotSettings.Mode == "Rage" then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, TargetPos)
            elseif AimbotSettings.Mode == "Normal" then
                local NewCF = CFrame.new(Camera.CFrame.Position, TargetPos)
                Camera.CFrame = Camera.CFrame:Lerp(NewCF, 0.2)
            elseif AimbotSettings.Mode == "Legit" then
                local NewCF = CFrame.new(Camera.CFrame.Position, TargetPos)
                Camera.CFrame = Camera.CFrame:Lerp(NewCF, 0.05)
            end
        end
    end
end)

